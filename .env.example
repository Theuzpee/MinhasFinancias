# n8n JWT secret for session token signing
N8N_JWT_SECRET=your_jwt_secret_here

# Google Gemini API key (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase PostgreSQL connection (Database Settings > Connection Info)
DB_POSTGRESDB_HOST=db.your-project-ref.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your_supabase_db_password_here

# Cloudflare Tunnel public URL (used by n8n for webhook base URL and CORS)
WEBHOOK_URL=https://api.yourdomain.com
N8N_CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
